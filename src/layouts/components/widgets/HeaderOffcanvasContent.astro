---
import social from "@/config/social.json";
import ReactIcons from "@/helpers/ReactIcons.astro";
import parseTomlToJson from "@/lib/utils/parseTomlToJson";
import Logo from "../global/Logo.astro";
import { markdownify } from "@/lib/utils/textConverter";
import Social from "./Social.astro";
import CustomButton from "@/components/CustomButton.astro";
import Navbar from "../global/header/Navbar.astro";
import { useTranslations } from "@/lib/utils/languageParser";

const {
  settings: {
    headerOffcanvas: { enable, logo, description, button },
    contactInfo: { address, phone, email },
  },
} = parseTomlToJson("./src/config/config.toml");

const t = await useTranslations(Astro.currentLocale as string);

const { offcanvas } = Astro.props;

if (!enable) {
  return null;
}
---

<div
  class="h-screen space-y-10 overflow-auto px-8 pt-20 pb-5 md:px-16 md:pt-32 md:pb-10"
  style="background-color: #007d8c; color: #ffffff;">
  <button
    type="button"
    data-hs-overlay={`#${offcanvas}`}
    title="Close offcanvas"
    class="absolute top-5 end-7 z-20 inline-flex h-14 w-14 items-center justify-center gap-x-2 rounded-full border-2 text-sm font-medium transition-all duration-500 ease-out hover:rotate-90"
    style="border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.1); color: #ffffff;"
    aria-expanded="true">
    <ReactIcons icon="IoMdClose" class="text-2xl" />
  </button>

  <Logo class="justify-start" width="11.25rem" height="3.125rem" src={logo} />
  <div class="lg:pb-10" style="border-bottom: 1px solid rgba(255,255,255,0.2);">
    {
      (description || t("headerOffcanvas.description")) && (
        <p
          class="text-lg"
          style="color: #e1ffa5;"
          set:html={markdownify(
            description || t("headerOffcanvas.description"),
          )}
        />
      )
    }
  </div>
  <div class="py-10 lg:hidden" style="border-top: 1px solid rgba(255,255,255,0.2); border-bottom: 1px solid rgba(255,255,255,0.2);">
    <Navbar isMobile={true} />
  </div>

  <div
    class="font-secondary text-sm/loose uppercase offcanvas-contact">
    {address && <address class="not-italic" set:html={markdownify(address)} />}
    {phone && <p class="mt-4 md:mt-6" set:html={markdownify(phone)} />}
    {email && <p set:html={markdownify(email)} />}
  </div>

  <Social
    linkType="follow"
    size="md"
    list={social.main.filter((social) => social.enable)}
  />

  <CustomButton
    variant="circle"
    hoverEffect="magnetic"
    class="btn-accent m-0 ms-auto hidden justify-center lg:flex"
    label={button?.label || t("headerOffcanvas.buttonLabel")}
    {...button}
  />
</div>
