<script>
  (() => {
    const cards = document.querySelectorAll<HTMLElement>("[data-pn-card]");
    const slides = document.querySelectorAll<HTMLElement>("[data-pn-slide]");
    if (!cards.length || !slides.length) return;

    let activeIdx = 0;

    function setActive(idx: number) {
      if (idx === activeIdx) return;
      activeIdx = idx;

      // Switch slides
      slides.forEach((s) => s.classList.remove("pn-img-slide--active"));
      const target = document.querySelector(`[data-pn-slide="${idx}"]`);
      if (target) target.classList.add("pn-img-slide--active");

      // Highlight active card
      cards.forEach((c) => c.classList.remove("pn-card--active"));
      cards[idx]?.classList.add("pn-card--active");
    }

    // Activate first card immediately
    cards[0]?.classList.add("pn-card--active");

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = Number((entry.target as HTMLElement).dataset.pnCard ?? 0);
            setActive(idx);
          }
        });
      },
      {
        rootMargin: "-30% 0px -30% 0px",
        threshold: 0,
      }
    );

    cards.forEach((card) => obs.observe(card));
  })();
</script>

<script>
  // -- Contador de quadras — Plano Fixo --
  (() => {
    const PRICES = ['149,99', '229,99', '299,99', '329,99', '349,99'];
    let count = 1;

    const pricingCards = document.querySelectorAll<HTMLElement>('.pn-pricing-wrap .bg-theme-light');
    const fixoCard = pricingCards[1];
    if (!fixoCard) return;

    const h3 = fixoCard.querySelector<HTMLElement>('h3');
    const priceWrap = fixoCard.querySelector<HTMLElement>('.font-secondary.font-semibold');
    if (!h3 || !priceWrap) return;

    // Encontra o text node do preço (antes do <span class="text-lg">)
    const priceTextNode = [...priceWrap.childNodes].find(
      (n) => n.nodeType === Node.TEXT_NODE
    ) as Text | undefined;
    if (!priceTextNode) return;

    // Estilos base para botão
    const btnStyle = `
      width:2rem;height:2.4rem;border-radius:0;border:none;
      background:#007d8c;color:#e1ffa5;font-size:1.2rem;line-height:1;
      cursor:pointer;display:flex;align-items:center;justify-content:center;
      transition:background 0.2s;flex-shrink:0;
    `;

    // Cria o contador
    const counter = document.createElement('div');
    counter.className = 'pn-quadra-counter';
    counter.style.cssText = `
      display:flex;align-items:center;gap:0;
      background:#002d3c;border-radius:0;padding:0;flex-shrink:0;overflow:hidden;
    `;
    counter.innerHTML = `
      <button class="pn-counter-btn" id="pn-dec" aria-label="Diminuir" style="${btnStyle}">−</button>
      <span id="pn-label" style="font-size:0.8rem;font-weight:600;color:#e1ffa5;white-space:nowrap;min-width:5.5rem;text-align:center;padding:0 0.5rem;">1 quadra</span>
      <button class="pn-counter-btn" id="pn-inc" aria-label="Aumentar" style="${btnStyle}">+</button>
    `;

    // Envolve h3 + contador numa linha flex
    const row = document.createElement('div');
    row.style.cssText = `
      display:flex;align-items:center;justify-content:space-between;
      gap:0.75rem;margin-bottom:1rem;
    `;
    h3.style.marginBottom = '0';
    h3.parentNode!.insertBefore(row, h3);
    row.appendChild(h3);
    row.appendChild(counter);

    // Subtítulo "primeiro mês grátis"
    const promo = document.createElement('p');
    promo.textContent = 'Primeiro mês grátis';
    promo.style.cssText = `
      font-size:1.1rem;font-weight:600;color:#007d8c;
      margin-top:0.25rem;margin-bottom:0;letter-spacing:0.03em;
      text-transform:uppercase;
    `;
    row.insertAdjacentElement('afterend', promo);

    const decBtn = document.getElementById('pn-dec') as HTMLButtonElement;
    const incBtn = document.getElementById('pn-inc') as HTMLButtonElement;
    const label  = document.getElementById('pn-label') as HTMLSpanElement;

    function render() {
      priceTextNode.nodeValue = `R$ ${PRICES[count - 1]}`;
      label.textContent = `${count} quadra${count > 1 ? 's' : ''}`;
      decBtn.disabled = count === 1;
      incBtn.disabled = count === PRICES.length;
    }

    decBtn.addEventListener('click', () => { if (count > 1) { count--; render(); } });
    incBtn.addEventListener('click', () => { if (count < PRICES.length) { count++; render(); } });

    render();
  })();
</script>
