---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";

const SITE_URL = "https://minhaquadra.com.br";

const estados = (await getCollection("estados")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title, "pt-BR"),
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Cidades", item: `${SITE_URL}/cidades/` },
  ],
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Cidades — Minha Quadra",
  description:
    "Encontre quadras esportivas para alugar na sua cidade. Selecione o estado para ver as opções disponíveis.",
  url: `${SITE_URL}/cidades/`,
  publisher: {
    "@type": "Organization",
    name: "Minha Quadra",
    url: SITE_URL,
  },
};
---

<Base
  metaTitle="Quadras Esportivas por Cidade — Encontre e Reserve Online | Minha Quadra"
  metaDescription="Encontre quadras esportivas para alugar na sua cidade. Beach tennis, tênis, futevôlei, society e mais. Compare preços e reserve online pelo Minha Quadra."
  canonical={`${SITE_URL}/cidades/`}
  fitToScreen={false}
  hasHeaderDarkBackground={true}
  footerLayout="footer-3"
  disableTagline={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />

  <!-- Breadcrumb -->
  <nav class="cd-bc" aria-label="Breadcrumb">
    <div class="container">
      <ol class="cd-bc__list" role="list">
        <li role="listitem"><a href="/" class="cd-bc__link">Home</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><span class="cd-bc__current">Cidades</span></li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="cd-hero">
    <div class="container">
      <div class="mx-auto max-w-7xl">
        <h1>
          <span class="cd-hero__line1 block" data-aos="reveal-anim-left">Quadras esportivas</span>
          <span class="cd-hero__line2 block" data-aos="reveal-anim-right">por cidade.</span>
        </h1>
        <p class="cd-hero__subtitle mt-8 max-w-2xl" data-aos="fade-up" data-aos-delay="200">
          Encontre quadras para alugar na sua cidade. Selecione o estado para ver as opções disponíveis.
        </p>
      </div>
    </div>
  </section>

  <!-- Grid de estados -->
  <section class="cd-grid-section">
    <div class="container">
      <div class="cd-grid">
        {estados.map((estado, i) => (
          <a
            href={`/cidades/${estado.data.slug}/`}
            class="cd-card"
            data-aos="fade-up"
            data-aos-delay={i * 60}
          >
            <div class="cd-card__body">
              <span class="cd-card__sigla">{estado.data.sigla}</span>
              <h2 class="cd-card__name">{estado.data.title}</h2>
              <span class="cd-card__meta">
                {estado.data.cidades.length} {estado.data.cidades.length === 1 ? "cidade disponível" : "cidades disponíveis"}
              </span>
              <span class="cd-card__cta">
                Ver cidades <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* Breadcrumb */
  .cd-bc {
    background-color: #002d3c;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 6rem;
  }
  .cd-bc .container {
    padding-top: 0.875rem;
    padding-bottom: 0.875rem;
  }
  .cd-bc__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
  }
  .cd-bc__link {
    color: rgba(245, 245, 245, 0.55);
    text-decoration: none;
    transition: color 0.2s;
  }
  .cd-bc__link:hover { color: #b4fa50; }
  .cd-bc__sep { color: rgba(245, 245, 245, 0.25); user-select: none; }
  .cd-bc__current { color: #b4fa50; font-weight: 500; }

  /* Hero */
  .cd-hero {
    background-color: #002d3c;
    padding-top: 5rem;
    padding-bottom: 6rem;
    overflow-x: hidden;
  }
  .cd-hero__line1 {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 600;
    color: #f5f5f5;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .cd-hero__line2 {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 600;
    color: #b4fa50;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .cd-hero__subtitle {
    font-size: 1.125rem;
    color: rgba(245, 245, 245, 0.8);
    line-height: 1.75;
  }
  @media (min-width: 768px) {
    .cd-hero__subtitle { font-size: 1.25rem; }
  }

  /* Grid */
  .cd-grid-section {
    background-color: #007d8c;
    padding-top: 5rem;
    padding-bottom: 7rem;
  }
  .cd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .cd-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cd-grid { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }

  /* Card */
  .cd-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background-color: #002d3c;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(225, 255, 165, 0.1);
  }
  .cd-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    border-color: rgba(180, 250, 80, 0.45);
  }
  .cd-card__body {
    padding: 2rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cd-card__sigla {
    font-size: 0.75rem;
    font-weight: 700;
    color: #b4fa50;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .cd-card__name {
    font-size: 1.5rem;
    font-weight: 600;
    color: #e1ffa5;
    margin: 0;
    line-height: 1.3;
  }
  .cd-card__meta {
    font-size: 0.875rem;
    color: rgba(245, 245, 245, 0.65);
  }
  .cd-card__cta {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: rgba(245, 245, 245, 0.7);
    transition: color 0.2s;
  }
  .cd-card:hover .cd-card__cta { color: #b4fa50; }
  .cd-card__cta span { color: #b4fa50; transition: transform 0.2s; display: inline-block; }
  .cd-card:hover .cd-card__cta span { transform: translateX(4px); }
</style>
