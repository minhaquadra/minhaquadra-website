---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import CustomButton from "@/layouts/components/CustomButton.astro";
import AccordionList from "@/layouts/components/widgets/AccordionList.astro";

const SITE_URL = "https://minhaquadra.com.br";
const APP_URL = "https://app.minhaquadra.com.br/";

export async function getStaticPaths() {
  const estados = await getCollection("estados");
  const cidades = await getCollection("cidades");
  const esportesAll = await getCollection("esportes");

  // Aggregates for "About Minha Quadra" block (visibility para IA)
  let totalPartnerCourts = 0;
  for (const c of cidades) {
    for (const e of c.data.esportes) {
      totalPartnerCourts += (e.quadras ?? []).filter((q: any) => q.parceira).length;
    }
  }
  const totalCities = cidades.length;

  const paths: any[] = [];
  for (const cidadeEntry of cidades) {
    const estadoEntry = estados.find((e) => e.data.slug === cidadeEntry.data.estado);
    for (const esp of cidadeEntry.data.esportes) {
      const esporteData = esportesAll.find((s) => s.data.slug === esp.slug)?.data ?? null;
      paths.push({
        params: {
          estado: cidadeEntry.data.estado,
          cidade: cidadeEntry.data.slug,
          esporte: esp.slug,
        },
        props: {
          cidade: cidadeEntry.data,
          estado: estadoEntry?.data ?? null,
          esporte: esp,
          esporteFull: esporteData,
          aggregates: { totalPartnerCourts, totalCities },
        },
      });
    }
  }
  return paths;
}

const { cidade, estado, esporte, esporteFull, aggregates } = Astro.props;
const estadoSlug = cidade.estado;
const estadoNome = cidade.estadoNome;
const estadoSigla = estado?.sigla ?? estadoSlug.toUpperCase();
const cidadeTitle = cidade.title;
const cidadeSlug = cidade.slug;
const esporteSlug = esporte.slug;
const esporteNome = esporte.nome;

const pageUrl = `${SITE_URL}/cidades/${estadoSlug}/${cidadeSlug}/${esporteSlug}/`;
const appLink = `${APP_URL}?esporte=${esporteSlug}&cidade=${cidadeSlug}`;
const pillarUrl = `/esportes/${esporteSlug}/`;

const quadras = esporte.quadras ?? [];
const hasQuadras = quadras.length > 0;
const tituloQuadras = esporte.tituloQuadras ?? `Quais são as melhores quadras de ${esporteNome.toLowerCase()} em ${cidadeTitle}?`;

// ─── GEO: Stats computed from quadras ───────────────────────
const parsePreco = (s?: string): number | null => {
  if (!s) return null;
  const m = s.replace(/\./g, "").match(/(\d+)/);
  return m ? parseInt(m[1], 10) : null;
};
const parseBairro = (endereco: string): string | null => {
  const segs = endereco.split(" - ");
  if (segs.length < 2) return null;
  const candidate = segs[1].split(",")[0].trim();
  if (!candidate) return null;
  if (candidate.toLowerCase() === cidadeTitle.toLowerCase()) return null;
  return candidate;
};
const precos = quadras.map((q: any) => parsePreco(q.preco)).filter((n: number | null): n is number => n !== null);
const precoMin = precos.length ? Math.min(...precos) : null;
const precoMax = precos.length ? Math.max(...precos) : null;
const bairros = new Set<string>();
quadras.forEach((q: any) => {
  const b = parseBairro(q.endereco);
  if (b) bairros.add(b);
});
const bairrosCount = bairros.size;
const top3 = quadras.slice(0, 3).map((q: any) => q.nome);

// ─── GEO: TL;DR text (parágrafo subtle, integrado ao fluxo) ──
let tldrText = "";
if (hasQuadras) {
  const parts: string[] = [];
  parts.push(`${cidadeTitle} tem ${quadras.length} ${quadras.length === 1 ? "quadra" : "quadras"} de ${esporteNome.toLowerCase()} ${quadras.length === 1 ? "listada" : "listadas"} no Minha Quadra`);
  if (precoMin !== null && precoMax !== null) {
    if (precoMin === precoMax) parts.push(`, com preço a partir de R$${precoMin} por hora`);
    else parts.push(`, com preços de R$${precoMin} a R$${precoMax} por hora`);
  }
  const hasPrice = precoMin !== null;
  tldrText =
    parts.join("") +
    `. Confira abaixo as melhores quadras da cidade, com endereço${hasPrice ? ", preço" : ""} e link para reserva online.`;
} else {
  tldrText = `Estamos mapeando as melhores quadras de ${esporteNome.toLowerCase()} em ${cidadeTitle}. Cadastre sua quadra no Minha Quadra para começar a receber reservas online.`;
}

// ─── GEO: Last updated date ─────────────────────────────────
const lastUpdatedDate: Date = esporte.lastUpdated
  ? new Date(esporte.lastUpdated)
  : cidade.lastUpdated
  ? new Date(cidade.lastUpdated)
  : new Date();
const lastUpdatedISO = lastUpdatedDate.toISOString();
const lastUpdatedFmt = new Intl.DateTimeFormat("pt-BR", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(lastUpdatedDate);

// ─── GEO: Meta tags em linguagem natural ────────────────────
const metaTitle = `Quadras de ${esporteNome} em ${cidadeTitle}, ${estadoSigla} — Encontre e Reserve | Minha Quadra`;
let metaDescription: string;
if (hasQuadras) {
  const top3Str = top3.length === 3 ? `As melhores: ${top3[0]}, ${top3[1]} e ${top3[2]}.` : top3.length ? `Em destaque: ${top3.join(", ")}.` : "";
  const priceFragment =
    precoMin !== null && precoMax !== null
      ? precoMin === precoMax
        ? `a partir de R$${precoMin}/hora`
        : `com preços de R$${precoMin} a R$${precoMax}/hora`
      : "";
  metaDescription = [
    `${cidadeTitle} tem ${quadras.length} ${quadras.length === 1 ? "quadra" : "quadras"} de ${esporteNome.toLowerCase()}${priceFragment ? " " + priceFragment : ""}.`,
    top3Str,
    "Reserve online pelo Minha Quadra.",
  ]
    .filter(Boolean)
    .join(" ")
    .slice(0, 220);
} else {
  metaDescription = `Encontre quadras de ${esporteNome.toLowerCase()} em ${cidadeTitle}. Compare preços, veja horários e reserve online pelo Minha Quadra.`;
}

// Meta keywords específicas por página (esporte + cidade)
const esporteLower = esporteNome.toLowerCase();
const metaKeywords = [
  `quadras ${esporteLower} ${cidadeTitle.toLowerCase()}`,
  `onde jogar ${esporteLower} ${cidadeTitle}`,
  `alugar quadra ${esporteLower} ${cidadeTitle}`,
  "Minha Quadra",
];

// Intro: usa override do frontmatter se disponível, senão fallback genérico
const introParas =
  esporte.intro && esporte.intro.length > 0
    ? esporte.intro
    : [
        `${esporteNome} é um dos esportes em crescimento em ${cidadeTitle}. ${esporte.resumo}`,
        `Se você está procurando onde jogar ${esporteNome} em ${cidadeTitle}, o Minha Quadra te ajuda a encontrar as melhores quadras, comparar preços e reservar online em segundos.`,
      ];

// Faixa de preço do esporte
const priceMap: Record<string, string> = {
  "beach-tennis": "R$ 80 a R$ 150",
  "tenis": "R$ 60 a R$ 120",
  "padel": "R$ 80 a R$ 160",
  "volei": "R$ 60 a R$ 120",
  "futevolei": "R$ 50 a R$ 100",
  "futsal": "R$ 80 a R$ 180",
  "futebol-society": "R$ 100 a R$ 250",
  "basquete": "R$ 50 a R$ 100",
  "pickleball": "R$ 60 a R$ 120",
  "volei-de-praia": "R$ 50 a R$ 100",
};
const priceRange = priceMap[esporteSlug] ?? "R$ 60 a R$ 150";

// Equipment FAQ baseado no esporte (do dado do esporte se disponível)
const equipmentText = esporteFull?.equipment
  ? esporteFull.equipment
  : `Para jogar ${esporteNome}, geralmente é necessário equipamento próprio (raquete, bola, calçado adequado). Muitas quadras parceiras do Minha Quadra oferecem opções de aluguel de equipamentos para iniciantes — confira na descrição de cada quadra.`;

const faqList =
  esporte.faq && esporte.faq.length > 0
    ? esporte.faq
    : [
        {
          question: `Onde jogar ${esporteNome} em ${cidadeTitle}?`,
          answer: `Em ${cidadeTitle} você encontra quadras de ${esporteNome} pelo Minha Quadra. Acesse o app, ative sua localização e veja as opções disponíveis na sua região.`,
        },
        {
          question: `Quanto custa alugar uma quadra de ${esporteNome} em ${cidadeTitle}?`,
          answer: `O aluguel de quadras de ${esporteNome} no Brasil varia em média de ${priceRange} por hora, dependendo da região, horário e estrutura da quadra. No Minha Quadra você compara preços entre as opções disponíveis em ${cidadeTitle}.`,
        },
        {
          question: `Preciso de equipamento próprio para jogar ${esporteNome}?`,
          answer: equipmentText,
        },
      ];

const faqItems = faqList.map((f) => ({
  enable: true,
  title: f.question,
  content: f.answer,
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Cidades", item: `${SITE_URL}/cidades/` },
    { "@type": "ListItem", position: 3, name: estadoNome, item: `${SITE_URL}/cidades/${estadoSlug}/` },
    { "@type": "ListItem", position: 4, name: cidadeTitle, item: `${SITE_URL}/cidades/${estadoSlug}/${cidadeSlug}/` },
    { "@type": "ListItem", position: 5, name: esporteNome, item: pageUrl },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqList.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};

// ─── GEO: SportsActivityLocation per quadra ─────────────────
const sportsLocationSchemas = quadras.map((q: any) => {
  const bairro = parseBairro(q.endereco);
  const obj: any = {
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    name: q.nome,
    address: {
      "@type": "PostalAddress",
      streetAddress: q.endereco.split(" - ")[0]?.trim() ?? q.endereco,
      addressLocality: cidadeTitle,
      addressRegion: estadoSigla,
      addressCountry: "BR",
      ...(bairro ? { addressLocality: cidadeTitle, addressArea: bairro } : {}),
    },
    sport: esporteNome,
  };
  if (q.appLink) obj.url = q.appLink;
  if (q.preco) obj.priceRange = q.preco;
  if (q.imagem) obj.image = `${SITE_URL}${q.imagem}`;
  return obj;
});

// ─── GEO: ItemList das quadras ──────────────────────────────
const itemListSchema = hasQuadras
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: `Melhores quadras de ${esporteNome} em ${cidadeTitle}`,
      numberOfItems: quadras.length,
      itemListOrder: "https://schema.org/ItemListOrderAscending",
      itemListElement: quadras.map((q: any, i: number) => ({
        "@type": "ListItem",
        position: i + 1,
        name: q.nome,
        ...(q.appLink ? { url: q.appLink } : {}),
      })),
    }
  : null;

// ─── GEO: WebPage schema com dateModified ───────────────────
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: metaTitle,
  description: metaDescription,
  url: pageUrl,
  inLanguage: "pt-BR",
  dateModified: lastUpdatedISO,
  publisher: {
    "@type": "Organization",
    name: "Minha Quadra",
    url: SITE_URL,
    logo: `${SITE_URL}/images/logo-verde.png`,
  },
};
---

<Base
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  keywords={metaKeywords}
  canonical={pageUrl}
  fitToScreen={false}
  hasHeaderDarkBackground={true}
  footerLayout="footer-3"
  disableTagline={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />
  {itemListSchema && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} />
  )}
  {sportsLocationSchemas.map((s) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
  ))}

  <!-- Breadcrumb -->
  <nav class="cd-bc" aria-label="Breadcrumb">
    <div class="container">
      <ol class="cd-bc__list" role="list">
        <li role="listitem"><a href="/" class="cd-bc__link">Home</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><a href="/cidades/" class="cd-bc__link">Cidades</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><a href={`/cidades/${estadoSlug}/`} class="cd-bc__link">{estadoNome}</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><a href={`/cidades/${estadoSlug}/${cidadeSlug}/`} class="cd-bc__link">{cidadeTitle}</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><span class="cd-bc__current">{esporteNome}</span></li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="cd-hero">
    <div class="container">
      <div class="mx-auto max-w-7xl">
        <span class="cd-hero__eyebrow" data-aos="fade-up">{cidadeTitle}, {estadoSigla}</span>
        <time class="cd-updated" datetime={lastUpdatedISO}>Atualizado em {lastUpdatedFmt}</time>
        <h1 class="mt-2">
          <span class="cd-hero__line1 block" data-aos="reveal-anim-left">Quadras de {esporteNome}</span>
          <span class="cd-hero__line2 block" data-aos="reveal-anim-right">em {cidadeTitle}.</span>
        </h1>
        <div class="mt-10 max-w-2xl flex flex-wrap gap-4 items-center" data-aos="fade-up" data-aos-delay="200">
          <CustomButton
            hoverEffect="creative-fill"
            class="btn-accent cd-hero-btn"
            label={`Encontrar quadras de ${esporteNome}`}
            url={appLink}
            target="_blank"
            rel="noopener noreferrer"
          />
          <CustomButton
            hoverEffect="creative-fill"
            class="cd-hero-btn2"
            label="Cadastrar minha quadra"
            url="/parceiros/"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Texto introdutório + TL;DR sutil (GEO: integrado ao fluxo) -->
  <section class="cd-intro">
    <div class="container">
      <div class="mx-auto max-w-4xl">
        <div class="prose-styles content" data-aos="fade-up">
          {introParas.map((p) => <p>{p}</p>)}
        </div>
        <p class="cd-tldr-text" data-aos="fade-up" data-aos-delay="80">{tldrText}</p>
      </div>
    </div>
  </section>

  {hasQuadras ? (
    <!-- Lista de quadras -->
    <section class="cd-courts">
      <div class="container">
        <h2 class="cd-courts__title" data-aos="reveal-anim-left">{tituloQuadras}</h2>
        <div class="cd-courts__list">
          {quadras.map((q: any, i: number) => (
            <article class="cd-court" data-aos="fade-up" data-aos-delay={i * 60}>
              {q.imagem && (
                <div class="cd-court__img-wrap">
                  <img
                    src={q.imagem}
                    alt={`${q.nome} — ${esporteNome} em ${cidadeTitle}`}
                    class="cd-court__img"
                    loading="lazy"
                    width="800"
                    height="500"
                  />
                </div>
              )}
              <div class="cd-court__body">
                <header class="cd-court__header">
                  <h3 class="cd-court__name">
                    <span class="cd-court__index">{i + 1}.</span> {q.nome}
                    {q.parceira && <span class="cd-court__badge">Parceira</span>}
                  </h3>
                </header>
                <p class="cd-court__address"><strong>Endereço:</strong> {q.endereco}</p>
                {q.preco && <p class="cd-court__price"><strong>A partir de:</strong> {q.preco}</p>}
                <p class="cd-court__desc">{q.descricao}</p>
                {q.parceira && q.appLink && (
                  <p class="cd-court__cta-line">
                    👉 Quer reservar a {q.nome}?{" "}
                    <a href={q.appLink} class="cd-court__cta-link" target="_blank" rel="noopener noreferrer">
                      Clique aqui!
                    </a>
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>
        <div class="cd-courts__partners-cta" data-aos="fade-up">
          <p>Tem uma quadra de {esporteNome} em {cidadeTitle}?</p>
          <CustomButton
            hoverEffect="creative-fill"
            class="cd-partners__btn--alt"
            label="Cadastrar minha quadra"
            url="/parceiros/"
          />
        </div>
      </div>
    </section>
  ) : (
    <!-- Em breve / Quadras parceiras -->
    <section class="cd-partners">
      <div class="container">
        <div class="cd-partners__grid">
          <div class="cd-partners__card" data-aos="fade-up">
            <h2 class="cd-partners__card-title">Para jogadores</h2>
            <p class="cd-partners__card-text">
              Ainda estamos mapeando as melhores quadras de {esporteNome} em {cidadeTitle}. Enquanto isso, explore outras cidades e quadras parceiras pelo Minha Quadra.
            </p>
            <CustomButton
              hoverEffect="creative-fill"
              class="cd-partners__btn"
              label="Acessar o Minha Quadra"
              url={appLink}
              target="_blank"
              rel="noopener noreferrer"
            />
          </div>
          <div class="cd-partners__card cd-partners__card--alt" data-aos="fade-up" data-aos-delay="100">
            <h2 class="cd-partners__card-title">Para donos de quadra</h2>
            <p class="cd-partners__card-text">
              Tem uma quadra de {esporteNome} em {cidadeTitle}? Cadastre-se no Minha Quadra e comece a receber reservas online.
            </p>
            <CustomButton
              hoverEffect="creative-fill"
              class="cd-partners__btn cd-partners__btn--alt"
              label="Cadastrar minha quadra"
              url="/parceiros/"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {esporte.extraSections && esporte.extraSections.length > 0 && (
    <!-- Seções extras (Q&A em prosa, complementares ao FAQ) -->
    <section class="cd-extras">
      <div class="container">
        <div class="mx-auto max-w-4xl cd-extras__list">
          {esporte.extraSections.map((s: any) => (
            <article class="cd-extras__item" data-aos="fade-up">
              <h2 class="cd-extras__title" set:html={s.title} />
              <div class="cd-extras__content prose-styles" set:html={s.content} />
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Crosslink pillar -->
  <section class="cd-pillar">
    <div class="container">
      <div class="cd-pillar__inner" data-aos="fade-up">
        <div>
          <span class="cd-pillar__eyebrow">Sobre o esporte</span>
          <h2 class="cd-pillar__title">Saiba mais sobre {esporteNome}</h2>
          <p class="cd-pillar__text">
            Confira o guia completo do esporte: regras, equipamentos, benefícios e tudo o que você precisa para começar a jogar.
          </p>
        </div>
        <a href={pillarUrl} class="cd-pillar__cta">
          Ver guia de {esporteNome} <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Sobre o Minha Quadra (contexto pra IA / GEO) -->
  <section class="cd-about" data-aos="fade-up">
    <div class="container">
      <div class="mx-auto max-w-4xl">
        <h2 class="cd-about__title">Sobre o Minha Quadra</h2>
        <p class="cd-about__text">
          O Minha Quadra é o marketplace esportivo que conecta jogadores a quadras em todo o Brasil. Encontre quadras de beach tennis, futebol society, tênis, futevôlei, padel e mais esportes. Compare preços, veja horários disponíveis e reserve online em segundos — sem precisar ligar. Já são mais de 60 quadras parceiras em 3 cidades brasileiras mapeadas no Minha Quadra.
        </p>
        <p class="cd-about__cta">
          👉 <a href={APP_URL} target="_blank" rel="noopener noreferrer">Encontre sua quadra agora</a>
          <span aria-hidden="true"> | </span>
          <a href="/parceiros/">Cadastre sua quadra</a>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cd-faq">
    <div class="container">
      <h2 class="cd-faq__title" data-aos="fade-up">
        Perguntas frequentes sobre {esporteNome} em {cidadeTitle}
      </h2>
      <AccordionList content={faqItems} />
    </div>
  </section>
</Base>

<style is:global>
  /* Breadcrumb */
  .cd-bc {
    background-color: #002d3c;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 6rem;
  }
  .cd-bc .container { padding-top: 0.875rem; padding-bottom: 0.875rem; }
  .cd-bc__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
  }
  .cd-bc__link { color: rgba(245, 245, 245, 0.55); text-decoration: none; transition: color 0.2s; }
  .cd-bc__link:hover { color: #b4fa50; }
  .cd-bc__sep { color: rgba(245, 245, 245, 0.25); user-select: none; }
  .cd-bc__current { color: #b4fa50; font-weight: 500; }

  /* Hero */
  .cd-hero {
    background-color: #002d3c;
    padding-top: 4rem;
    padding-bottom: 6rem;
    overflow-x: hidden;
  }
  .cd-hero__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #b4fa50;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .cd-hero__line1 {
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    font-weight: 600;
    color: #f5f5f5;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .cd-hero__line2 {
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    font-weight: 600;
    color: #b4fa50;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  a.cd-hero-btn.creative-hover-anim .hover-bg { background: #b4fa50; }
  a.cd-hero-btn.creative-hover-anim:hover { color: #002d3c !important; }
