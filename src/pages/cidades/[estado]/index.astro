---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import CustomButton from "@/layouts/components/CustomButton.astro";

const SITE_URL = "https://minhaquadra.com.br";
const APP_URL = "https://app.minhaquadra.com.br/";

export async function getStaticPaths() {
  const estados = await getCollection("estados");
  const cidades = await getCollection("cidades");
  return estados.map((entry) => {
    const cidadesDoEstado = cidades
      .filter((c) => c.data.estado === entry.data.slug)
      .map((c) => c.data)
      .sort((a, b) => a.title.localeCompare(b.title, "pt-BR"));
    return {
      params: { estado: entry.data.slug },
      props: { estado: entry.data, cidades: cidadesDoEstado },
    };
  });
}

const { estado, cidades } = Astro.props;
const { title, sigla, slug, description, metaTitle, metaDescription } = estado;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Cidades", item: `${SITE_URL}/cidades/` },
    { "@type": "ListItem", position: 3, name: title, item: `${SITE_URL}/cidades/${slug}/` },
  ],
};
---

<Base
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  canonical={`${SITE_URL}/cidades/${slug}/`}
  fitToScreen={false}
  hasHeaderDarkBackground={true}
  footerLayout="footer-3"
  disableTagline={true}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="cd-bc" aria-label="Breadcrumb">
    <div class="container">
      <ol class="cd-bc__list" role="list">
        <li role="listitem"><a href="/" class="cd-bc__link">Home</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><a href="/cidades/" class="cd-bc__link">Cidades</a></li>
        <li aria-hidden="true" class="cd-bc__sep">/</li>
        <li role="listitem"><span class="cd-bc__current">{title}</span></li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="cd-hero">
    <div class="container">
      <div class="mx-auto max-w-7xl">
        <span class="cd-hero__eyebrow" data-aos="fade-up">{sigla}</span>
        <h1 class="mt-2">
          <span class="cd-hero__line1 block" data-aos="reveal-anim-left">Quadras esportivas em</span>
          <span class="cd-hero__line2 block" data-aos="reveal-anim-right">{title}.</span>
        </h1>
        <p class="cd-hero__subtitle mt-8 max-w-2xl" data-aos="fade-up" data-aos-delay="200">
          {description}
        </p>
      </div>
    </div>
  </section>

  <!-- Grid de cidades -->
  <section class="cd-grid-section">
    <div class="container">
      {cidades.length > 0 ? (
        <div class="cd-grid">
          {cidades.map((cidade: any, i: number) => (
            <a
              href={`/cidades/${slug}/${cidade.slug}/`}
              class="cd-card"
              data-aos="fade-up"
              data-aos-delay={i * 60}
            >
              <div class="cd-card__body">
                <span class="cd-card__sigla">{title}</span>
                <h2 class="cd-card__name">{cidade.title}</h2>
                <span class="cd-card__meta">
                  {cidade.esportes.length} {cidade.esportes.length === 1 ? "esporte disponível" : "esportes disponíveis"}
                </span>
                <span class="cd-card__cta">
                  Ver quadras <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="cd-empty">Em breve teremos cidades disponíveis em {title}.</p>
      )}
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cd-cta-mid">
    <div class="container">
      <div class="grid gap-x-20 gap-y-10 lg:grid-cols-2 lg:place-items-center lg:gap-y-20">
        <div class="max-w-3xl">
          <h2 class="cd-cta-mid__title" data-aos="reveal-anim-left">
            Encontre quadras na sua cidade
          </h2>
        </div>
        <div class="max-w-lg space-y-10">
          <p class="cd-cta-mid__desc" data-aos="fade-up" data-aos-delay="100">
            Compare opções, veja horários disponíveis e reserve sua quadra online em segundos.
          </p>
          <div data-aos="fade-up" data-aos-delay="200">
            <CustomButton
              hoverEffect="creative-fill"
              class="cd-cta-btn"
              label="Explorar quadras"
              url={APP_URL}
              target="_blank"
              rel="noopener noreferrer"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  /* Breadcrumb */
  .cd-bc {
    background-color: #002d3c;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 6rem;
  }
  .cd-bc .container { padding-top: 0.875rem; padding-bottom: 0.875rem; }
  .cd-bc__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
  }
  .cd-bc__link { color: rgba(245, 245, 245, 0.55); text-decoration: none; transition: color 0.2s; }
  .cd-bc__link:hover { color: #b4fa50; }
  .cd-bc__sep { color: rgba(245, 245, 245, 0.25); user-select: none; }
  .cd-bc__current { color: #b4fa50; font-weight: 500; }

  /* Hero */
  .cd-hero {
    background-color: #002d3c;
    padding-top: 4rem;
    padding-bottom: 6rem;
    overflow-x: hidden;
  }
  .cd-hero__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #b4fa50;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .cd-hero__line1 {
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    font-weight: 600;
    color: #f5f5f5;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .cd-hero__line2 {
    font-size: clamp(2.25rem, 5.5vw, 5rem);
    font-weight: 600;
    color: #b4fa50;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .cd-hero__subtitle {
    font-size: 1.125rem;
    color: rgba(245, 245, 245, 0.8);
    line-height: 1.75;
  }
  @media (min-width: 768px) {
    .cd-hero__subtitle { font-size: 1.25rem; }
  }

  /* Grid */
  .cd-grid-section {
    background-color: #007d8c;
    padding-top: 5rem;
    padding-bottom: 7rem;
  }
  .cd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .cd-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cd-grid { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }
  .cd-empty {
    color: rgba(245, 245, 245, 0.85);
    font-size: 1.125rem;
    text-align: center;
    padding: 3rem 0;
  }

  /* Card */
  .cd-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background-color: #002d3c;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(225, 255, 165, 0.1);
  }
  .cd-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    border-color: rgba(180, 250, 80, 0.45);
  }
  .cd-card__body {
    padding: 2rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cd-card__sigla {
    font-size: 0.75rem;
    font-weight: 700;
    color: #b4fa50;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .cd-card__name {
    font-size: 1.5rem;
    font-weight: 600;
    color: #e1ffa5;
    margin: 0;
    line-height: 1.3;
  }
  .cd-card__meta {
    font-size: 0.875rem;
    color: rgba(245, 245, 245, 0.65);
  }
  .cd-card__cta {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: rgba(245, 245, 245, 0.7);
    transition: color 0.2s;
  }
  .cd-card:hover .cd-card__cta { color: #b4fa50; }
  .cd-card__cta span { color: #b4fa50; transition: transform 0.2s; display: inline-block; }
  .cd-card:hover .cd-card__cta span { transform: translateX(4px); }

  /* CTA Mid */
  .cd-cta-mid {
    background-color: #b4fa50;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  .cd-cta-mid__title {
    font-size: clamp(2.25rem, 5vw, 5rem);
    font-weight: 600;
    color: #002d3c;
    line-height: 1.1;
  }
  .cd-cta-mid__desc {
    font-size: 1.125rem;
    color: #002d3c;
    line-height: 1.75;
  }
  a.cd-cta-btn.btn {
    background-color: #002d3c !important;
    border-color: #002d3c !important;
    color: #e1ffa5 !important;
    font-weight: 500;
  }
  a.cd-cta-btn.creative-hover-anim .hover-bg { background: #007d8c; }
  a.cd-cta-btn.creative-hover-anim:hover {
    color: #e1ffa5 !important;
    border-color: #007d8c !important;
  }
</style>
