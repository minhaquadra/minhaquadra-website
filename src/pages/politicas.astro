---
import Base from "@/layouts/Base.astro";
---

<Base metaTitle="Termos e Políticas — Minha Quadra">

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section class="pol-hero">
    <div class="container">
      <div class="mx-auto max-w-7xl">
        <h1 data-aos="reveal-anim-left">
          <span class="text-display-5 md:text-display-4 leading-tight font-semibold pol-title-line1">Termos e </span><span class="text-display-5 md:text-display-4 leading-tight font-semibold pol-title-line2">políticas.</span>
        </h1>
        <p class="pol-subtitle" data-aos="fade-up" data-aos-delay="200">
          Acesse os documentos legais da plataforma Minha Quadra.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Cards ─────────────────────────────────────────────────────── -->
  <section class="pol-cards">
    <div class="container">
      <div class="pol-grid">

        <!-- Termos de Uso -->
        <a href="/termos-de-uso/" class="pol-card" data-aos="fade-up">
          <div class="flex min-h-full flex-col space-y-16 p-6 md:px-8 md:py-10">
            <div class="flex min-h-full flex-1 flex-col items-start space-y-8">
              <div class="flex w-full flex-wrap-reverse justify-between gap-5 md:flex-row">
                <h2 class="pol-card-title text-h5">Termos de Uso</h2>
                <div class="pol-card-icon h-10 w-10 flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                  </svg>
                </div>
              </div>
              <p class="pol-card-desc">Leia todos os Termos de Uso da plataforma Minha Quadra.</p>
            </div>
          </div>
        </a>

        <!-- Política de Privacidade -->
        <a href="/politica-de-privacidade/" class="pol-card" data-aos="fade-up" data-aos-delay="100">
          <div class="flex min-h-full flex-col space-y-16 p-6 md:px-8 md:py-10">
            <div class="flex min-h-full flex-1 flex-col items-start space-y-8">
              <div class="flex w-full flex-wrap-reverse justify-between gap-5 md:flex-row">
                <h2 class="pol-card-title text-h5">Política de Privacidade</h2>
                <div class="pol-card-icon h-10 w-10 flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                </div>
              </div>
              <p class="pol-card-desc">Acesse a Política de Privacidade do Minha Quadra.</p>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .pol-hero {
    background-color: #002d3c;
    padding-top: 8rem;
    padding-bottom: 6rem;
    padding-left: max(2rem, 6vw);
    padding-right: max(2rem, 6vw);
    overflow-x: hidden;
  }

  .pol-title-line1 {
    color: #f5f5f5;
  }

  .pol-title-line2 {
    color: #b4fa50;
  }

  .pol-subtitle {
    color: #f5f5f5;
    font-size: 1.125rem;
    margin-top: 2rem;
    max-width: 36rem;
  }

  /* ── Cards section ────────────────────────────────────────────────── */
  .pol-cards {
    background-color: #002d3c;
    padding-top: 1rem;
    padding-bottom: 8rem;
    padding-left: max(2rem, 6vw);
    padding-right: max(2rem, 6vw);
  }

  .pol-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 56rem;
  }

  @media (min-width: 640px) {
    .pol-grid { grid-template-columns: 1fr 1fr; }
  }

  /* ── Card — mesmo estilo do mq-step-card ─────────────────────────── */
  .pol-card {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(225, 255, 165, 0.1);
    text-decoration: none;
    display: block;
    transition: background-color 0.25s, border-color 0.25s;
  }

  .pol-card:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(180, 250, 80, 0.25);
  }

  .pol-card-title {
    color: #e1ffa5;
    font-weight: 600;
  }

  .pol-card-desc {
    color: #f5f5f5;
    line-height: 1.65;
  }

  .pol-card-icon {
    color: #b4fa50;
  }

  .pol-card-icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }
</style>
